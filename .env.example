# ═══════════════════════════════════════════════════
# ElectroPMS — Ortam Değişkenleri
# ═══════════════════════════════════════════════════
# Bu dosyayı .env olarak kopyala ve değerleri doldur
# cp .env.example .env

# ─── DATABASE ─────────────────────────────────────
DATABASE_URL=postgresql://electropms:secret@localhost:5432/electropms
REDIS_URL=redis://localhost:6379/0

# ─── SECURITY ─────────────────────────────────────
SECRET_KEY=change-this-to-a-random-256-bit-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ─── ANTHROPIC (Claude AI) ───────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# ─── LINE LOGIN + MESSAGING ──────────────────────
LINE_CHANNEL_ID=your-line-channel-id
LINE_CHANNEL_SECRET=your-line-channel-secret
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token
LINE_LOGIN_CALLBACK_URL=http://localhost:8000/api/auth/line/callback

# ─── FACEBOOK LOGIN ──────────────────────────────
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
FACEBOOK_CALLBACK_URL=http://localhost:8000/api/auth/facebook/callback

# ─── GOOGLE LOGIN ────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:8000/api/auth/google/callback

# ─── FIREBASE (Push Notifications) ───────────────
FIREBASE_PROJECT_ID=electropms
FIREBASE_PRIVATE_KEY_PATH=./firebase-service-account.json

# ─── APP CONFIG ──────────────────────────────────
APP_NAME=ElectroPMS
APP_ENV=development
APP_DEBUG=true
CORS_ORIGINS=http://localhost:5173,capacitor://localhost
UPLOAD_MAX_SIZE_MB=50
UPLOAD_DIR=./uploads
