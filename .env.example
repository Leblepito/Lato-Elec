# ═══════════════════════════════════════════════════
# ElectroPMS v6 — ตัวแปรสภาพแวดล้อม / Ortam Değişkenleri
# ═══════════════════════════════════════════════════
# cp .env.example .env → değerleri doldur / กรอกค่า

# ─── DATABASE ─────────────────────────────────────
DATABASE_URL=postgresql://electropms:secret@localhost:5432/electropms

# ─── SECURITY ─────────────────────────────────────
SECRET_KEY=change-this-to-a-random-256-bit-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ─── AI (Claude) ─────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# ─── LINE LOGIN + MESSAGING ──────────────────────
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_LOGIN_CALLBACK_URL=http://localhost:8000/api/auth/line/callback

# ─── FACEBOOK LOGIN ──────────────────────────────
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=http://localhost:8000/api/auth/facebook/callback

# ─── GOOGLE LOGIN ────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:8000/api/auth/google/callback

# ─── APP ─────────────────────────────────────────
APP_NAME=ElectroPMS
APP_ENV=development
CORS_ORIGINS=http://localhost:5173,capacitor://localhost
UPLOAD_DIR=./uploads
UPLOAD_MAX_SIZE_MB=50

# ─── RAILWAY (otomatik ayarlanır) ────────────────
# PORT=8000
